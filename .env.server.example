# Copy this file to .env before running docker compose.

# App
APP_PORT=3000
APP_PASSWORD=change-this-login-password
APP_ENCRYPTION_KEY=change-this-long-random-string
# Leave empty for auto-detection. Set false for plain HTTP/IP access, true for HTTPS-only reverse proxy setups.
APP_COOKIE_SECURE=

# PostgreSQL container
POSTGRES_DB=grad_research_hub
POSTGRES_USER=gradhub
POSTGRES_PASSWORD=change-this-database-password

# Zotero Web API
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=user
ZOTERO_COLLECTION_KEY=
ZOTERO_SYNC_LIMIT=100
