generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Paper {
  id         String   @id @default(cuid())
  title      String
  authors    String   @default("[]")
  year       Int?
  abstract   String?
  journal    String?
  doi        String?
  arxivId    String?
  zoteroKey  String?  @unique
  bibtexKey  String?
  category   String   @default("inbox")
  readStatus String   @default("unread")
  pdfUrl     String?
  externalUrl String?
  tags       String   @default("[]")
  notes      String?
  lastSyncedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  experiments Experiment[]

  @@index([readStatus])
  @@index([category])
  @@index([zoteroKey])
}

model Project {
  id          String      @id @default(cuid())
  title       String
  description String?
  status      String      @default("active")
  tags        String      @default("[]")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  milestones  Milestone[]
  experiments Experiment[]

  @@index([status])
}

model Milestone {
  id        String   @id @default(cuid())
  projectId String
  title     String
  dueDate   DateTime?
  status    String   @default("planned")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
  @@index([dueDate])
  @@index([status])
}

model Task {
  id          String    @id @default(cuid())
  milestoneId String?
  title       String
  description String?
  priority    String    @default("medium")
  status      String    @default("todo")
  dueDate     DateTime?
  tags        String    @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  milestone Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([priority])
  @@index([dueDate])
}

model Experiment {
  id          String   @id @default(cuid())
  projectId   String?
  title       String
  status      String   @default("running")
  template    String   @default("standard")
  content     String   @default("")
  attachments String   @default("[]")
  externalRunId String?
  repositoryUrl String?
  gitCommit   String?
  artifactPath String?
  tags        String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  papers  Paper[]
  results Result[]

  @@index([status])
  @@index([projectId])
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  folder    String   @default("Inbox")
  tags      String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([folder])
}

model Dataset {
  id          String   @id @default(cuid())
  name        String
  source      String?
  version     String?
  description String?
  path        String?
  externalUrl String?
  dvcPath     String?
  tags        String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  results Result[]
}

model Result {
  id           String   @id @default(cuid())
  experimentId String?
  datasetId    String?
  title        String
  metrics      String   @default("{}")
  config       String   @default("{}")
  mlflowRunId  String?
  dvcExpName   String?
  gitCommit    String?
  artifactPath String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  experiment Experiment? @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  dataset    Dataset?    @relation(fields: [datasetId], references: [id], onDelete: SetNull)

  @@index([experimentId])
  @@index([datasetId])
}

model AdminItem {
  id        String   @id @default(cuid())
  title     String
  type      String   @default("meeting")
  status    String   @default("todo")
  dueDate   DateTime?
  location  String?
  notes     String?
  tags      String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([dueDate])
}
