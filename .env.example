# Vercel/production: use PostgreSQL from Vercel Postgres, Neon, Supabase, etc.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Zotero Web API. Keep secrets in Vercel Environment Variables.
ZOTERO_API_KEY=""
ZOTERO_LIBRARY_ID=""
ZOTERO_LIBRARY_TYPE="user"
ZOTERO_COLLECTION_KEY=""
ZOTERO_SYNC_LIMIT="100"

# Required before saving AI API keys from the settings center.
APP_ENCRYPTION_KEY=""

# Optional but strongly recommended before public deployment.
APP_PASSWORD=""
